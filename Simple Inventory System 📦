# Simple Inventory System 📦
items = {}

while True:
    print("\n1. Add Item")
    print("2. View Items")
    print("3. Exit")

    choice = input("Choose: ")

    if choice == "1":
        name = input("Item name: ")
        qty = int(input("Quantity: "))
        items[name] = qty

    elif choice == "2":
        for k, v in items.items():
            print(k, ":", v)

    elif choice == "3":
        break
